# Secrets
.env
.env.*
!.env.example

# macOS
.DS_Store

# Python / uv
.venv/
__pycache__/
*.pyc
.pytest_cache/
.ruff_cache/
.mypy_cache/
dist/
build/
*.egg-info/

# Model weights and caches
~/.cache/huggingface/
weights/
models/

# Pipeline working data
music/
data/tracks/
data/stems/
data/lyrics/
data/structure/
data/shotplans/
data/keyframes/
data/clips/
data/clips-hq/
data/cuts/
data/logs/

# Any `outputs/` folder at any depth — POC runs, pipeline outputs, future
# experimental runs. Regenerable; don't bloat git history with binary media.
**/outputs/
# Historical archived variants
**/outputs_v1/
**/outputs_v2/
**/outputs_legacy/

# POC inputs derived from user's gitignored music/, and per-poc caches
pocs/*/inputs/
pocs/*/stems/
pocs/*/cache/
pocs/*/whisperx_cache/

# Editor (storyboard editor) runtime state
editor/data/
editor/web/node_modules/
editor/web/test-results/
editor/web/playwright-report/
editor/web/dist/

# Rendered video — regenerable, not suited to git
*.mp4

# Editors
.idea/
.vscode/
*.swp
