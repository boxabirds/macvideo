  "lines": [
    {
      "line_idx": 0,
      "text": "[Verse 1]"
    },
    {
      "line_idx": 1,
      "text": "Light finds me"
    },
    {
      "line_idx": 2,
      "text": "Before I ask it to"
    },
    {
      "line_idx": 3,
      "text": "Same window"
    },
    {
      "line_idx": 4,
      "text": "But the glass keeps thinning"
    },
    {
      "line_idx": 5,
      "text": "Something soft"
    },
    {
      "line_idx": 6,
      "text": "Slipping off its hanger"
    },
    {
      "line_idx": 7,
      "text": "A crease in the face"
    },
    {
      "line_idx": 8,
      "text": "That wasn't mine last winter"
    },
    {
      "line_idx": 9,
      "text": "[Chorus]"
    },
    {
      "line_idx": 10,
      "text": "I'm frightened of warmth leaving skin"
    },
    {
      "line_idx": 11,
      "text": "The weight of a breath"
    },
    {
      "line_idx": 12,
      "text": "I won't get again"
    },
    {
      "line_idx": 13,
      "text": "Blink and the colour bleeds out"
    },
    {
      "line_idx": 14,
      "text": "Frames go quiet but the hollow stays loud"
    },
    {
      "line_idx": 15,
      "text": "If I can't keep what I carry"
    },
    {
      "line_idx": 16,
      "text": "What am I carrying it for"
    },
    {
      "line_idx": 17,
      "text": "I'm frightened of warmth leaving skin"
    },
    {
      "line_idx": 18,
      "text": "And I feel it through your door"
    },
    {
      "line_idx": 19,
      "text": "Little paper boats"
    },
    {
      "line_idx": 20,
      "text": "Sinking in a drawer"
    },
    {
      "line_idx": 21,
      "text": "Names I whisper"
    },
    {
      "line_idx": 22,
      "text": "Then let go of in the hallway"
    },
    {
      "line_idx": 23,
      "text": "[Bridge]"
    },
    {
      "line_idx": 24,
      "text": "Tell me Is it wasted"
    },
    {
      "line_idx": 25,
      "text": "If I spend tonight just listening"
    },
    {
      "line_idx": 26,
      "text": "To the hum beneath the silence"
    },
    {
      "line_idx": 27,
      "text": "To the room slowly breathing"
    },
    {
      "line_idx": 28,
      "text": "To the hum beneath the silence"
    },
    {
      "line_idx": 29,
      "text": "To the room slowly breathing"
    },
    {
      "line_idx": 30,
      "text": "Promise me the ordinary hours"
    },
    {
      "line_idx": 31,
      "text": "Count the way the bright ones do"
    },
    {
      "line_idx": 32,
      "text": "'Cause I keep catching water"
    },
    {
      "line_idx": 33,
      "text": "While I'm spilling it with you"
    },
    {
      "line_idx": 34,
      "text": "[Final Chorus]"
    },
    {
      "line_idx": 35,
      "text": "I'm frightened of warmth leaving skin"
    },
    {
      "line_idx": 36,
      "text": "The weight of a breath"
    },
    {
      "line_idx": 37,
      "text": "I won't get again"
    },
    {
      "line_idx": 38,
      "text": "Blink and the colour bleeds out"
    },
    {
      "line_idx": 39,
      "text": "Still"
    },
    {
      "line_idx": 40,
      "text": "You're here in this slow"
    },
    {
      "line_idx": 41,
      "text": "Sinking light If"
    },
    {
      "line_idx": 42,
      "text": "I can't keep what I carry"
    },
    {
      "line_idx": 43,
      "text": "Let me just be where you are"
    },
    {
      "line_idx": 44,
      "text": "I'm frightened of warmth leaving skin"
    },
    {
      "line_idx": 45,
      "text": "But I'll take these hands"
    },
    {
      "line_idx": 46,
      "text": "Tangled in your peace"
    }
