  "lines": [
    {
      "line_idx": 0,
      "text": "He's arrived again"
    },
    {
      "line_idx": 1,
      "text": "Whispering in my ear"
    },
    {
      "line_idx": 2,
      "text": "Molten black"
    },
    {
      "line_idx": 3,
      "text": "Pooling in"
    },
    {
      "line_idx": 4,
      "text": "That's my little blackbird"
    },
    {
      "line_idx": 5,
      "text": "Little blackbird of noes"
    },
    {
      "line_idx": 6,
      "text": "I brush him away"
    },
    {
      "line_idx": 7,
      "text": "A deft hop, a flutter"
    },
    {
      "line_idx": 8,
      "text": "He pecks back"
    },
    {
      "line_idx": 9,
      "text": "Persistent"
    },
    {
      "line_idx": 10,
      "text": "Whispering again"
    },
    {
      "line_idx": 11,
      "text": "Oh why won't you"
    },
    {
      "line_idx": 12,
      "text": "Little blackbird"
    },
    {
      "line_idx": 13,
      "text": "Just fly away"
    },
    {
      "line_idx": 14,
      "text": "Carry your leaden bag of noes"
    },
    {
      "line_idx": 15,
      "text": "Leave some peace behind"
    },
    {
      "line_idx": 16,
      "text": "Clear out some space for yes"
    },
    {
      "line_idx": 17,
      "text": "Come on now"
    },
    {
      "line_idx": 18,
      "text": "Little blackbird"
    },
    {
      "line_idx": 19,
      "text": "Just fly away"
    },
    {
      "line_idx": 20,
      "text": "Take your leaden bag of noes"
    },
    {
      "line_idx": 21,
      "text": "He settles in now"
    },
    {
      "line_idx": 22,
      "text": "Makes himself at home"
    },
    {
      "line_idx": 23,
      "text": "Drapes himself across the afternoon"
    },
    {
      "line_idx": 24,
      "text": "Drinks my tea"
    },
    {
      "line_idx": 25,
      "text": "That's my little blackbird"
    },
    {
      "line_idx": 26,
      "text": "Little blackbird of noes"
    },
    {
      "line_idx": 27,
      "text": "I don't brush him away"
    },
    {
      "line_idx": 28,
      "text": "I pour him another"
    },
    {
      "line_idx": 29,
      "text": "He's the only one"
    },
    {
      "line_idx": 30,
      "text": "Who stayed this long"
    },
    {
      "line_idx": 31,
      "text": "Who bothered with my name"
    },
    {
      "line_idx": 32,
      "text": "Oh why won't you"
    },
    {
      "line_idx": 33,
      "text": "Little blackbird"
    },
    {
      "line_idx": 34,
      "text": "Just fly away"
    },
    {
      "line_idx": 35,
      "text": "Carry your laden bag of noes"
    },
    {
      "line_idx": 36,
      "text": "Leave some peace behind"
    },
    {
      "line_idx": 37,
      "text": "Clear out some space for yes"
    },
    {
      "line_idx": 38,
      "text": "Come on now"
    },
    {
      "line_idx": 39,
      "text": "Little blackbird"
    },
    {
      "line_idx": 40,
      "text": "Just fly away"
    },
    {
      "line_idx": 41,
      "text": "Take your laden bag of noes"
    },
    {
      "line_idx": 42,
      "text": "What was I \u2014"
    },
    {
      "line_idx": 43,
      "text": "Doesn't matter"
    },
    {
      "line_idx": 44,
      "text": "He knows"
    },
    {
      "line_idx": 45,
      "text": "He noes"
    },
    {
      "line_idx": 46,
      "text": "Same either way"
    },
    {
      "line_idx": 47,
      "text": "Somewhere a window's open"
    },
    {
      "line_idx": 48,
      "text": "Somewhere a kettle clicked"
    },
    {
      "line_idx": 49,
      "text": "I could \u2014"
    },
    {
      "line_idx": 50,
      "text": "No"
    },
    {
      "line_idx": 51,
      "text": "That's my little blackbird"
    },
    {
      "line_idx": 52,
      "text": "Little blackbird of noes"
    },
    {
      "line_idx": 53,
      "text": "Nobody knows"
    },
    {
      "line_idx": 54,
      "text": "Nobody knows enough to care"
    },
    {
      "line_idx": 55,
      "text": "Oh stay then"
    },
    {
      "line_idx": 56,
      "text": "Little blackbird"
    },
    {
      "line_idx": 57,
      "text": "Don't fly away"
    },
    {
      "line_idx": 58,
      "text": "Keep your gravid bag of noes"
    },
    {
      "line_idx": 59,
      "text": "There's no peace behind"
    },
    {
      "line_idx": 60,
      "text": "There's no space for yes"
    },
    {
      "line_idx": 61,
      "text": "Stay now"
    },
    {
      "line_idx": 62,
      "text": "Little blackbird"
    },
    {
      "line_idx": 63,
      "text": "Don't fly away"
    },
    {
      "line_idx": 64,
      "text": "You're my leaden bag of noes"
