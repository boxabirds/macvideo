{
  "name": "macvideo-editor-web",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bash scripts/dev.sh",
    "dev:vite-only": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "bun run test:unit",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "bun run test:e2e:fake",
    "test:e2e:fake": "EDITOR_E2E_SUITE=fake-backed bash scripts/e2e.sh",
    "test:e2e:product:diagnose": "cd ../.. && uv run python scripts/check_dev_environment.py --mode dev"
  },
  "dependencies": {
    "react": "19",
    "react-dom": "19",
    "react-router": "7",
    "swr": "^2.4.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bun": "latest",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "jsdom": "^29.0.2",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
